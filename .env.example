# Copie para um arquivo .env na RAIZ do projeto e preencha a API key.
# O .env nao e versionado (ver .gitignore).

# Regiao do Bedrock
AWS_REGION=us-east-1

# API key do Bedrock (bearer token). Gere no console da AWS (Amazon Bedrock > API keys).
AWS_BEARER_TOKEN_BEDROCK=

# Modelos (opcionais; ja tem padrao no codigo)
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# AstroCopilot — unico arquivo de ambiente (copie para .env na RAIZ do projeto).
# Nao versionado (ver .gitignore). Usado por agent-rag, voice-nlp e backend.

# ----- Amazon Bedrock (Frente 1 — RAG) -----
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# ----- Whisper + gTTS (Frente 2 — Voz) -----
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pt
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=0
WHISPER_INITIAL_PROMPT=Instrucoes da cabine. Tripulacao espacial, astronauta, EVA, ECLSS.
TTS_LANG=pt-br
TTS_MAX_CHARS=3500

# ----- Opcional (Windows / Hugging Face) -----
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ----- Dashboard (Frente 5 — so se rodar npm fora do Docker) -----
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000

